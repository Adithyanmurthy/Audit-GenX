{
  "coverage_rules": {
    "Comprehensive": {
      "covers_own_damage": true,
      "covers_third_party": true,
      "covers_theft": true,
      "covers_fire": true,
      "covers_natural_disaster": true,
      "policy_limit_inr": 1000000,
      "deductible_inr": 3000,
      "description": "Covers own damage, third-party liability, theft, fire, and natural disasters"
    },
    "Third-Party": {
      "covers_own_damage": false,
      "covers_third_party": true,
      "covers_theft": false,
      "covers_fire": false,
      "covers_natural_disaster": false,
      "policy_limit_inr": 500000,
      "deductible_inr": 0,
      "description": "Covers only third-party liability; does NOT cover own vehicle damage"
    }
  },
  "exclusions": {
    "Comprehensive": [
      "racing",
      "drunk driving",
      "commercial use without endorsement",
      "war",
      "nuclear"
    ],
    "Third-Party": [
      "own damage",
      "theft",
      "fire",
      "natural disaster",
      "racing",
      "drunk driving"
    ]
  },
  "required_documents": [
